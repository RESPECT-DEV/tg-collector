# Переменные окружения — содержат секреты (токены, пароли, URL)
# НИКОГДА не должны попадать в репозиторий
.env

# Зависимости — устанавливаются командой npm install из package.json
# Нет смысла хранить тысячи файлов в гите
node_modules/

# Системный файл macOS — создаётся автоматически, в проекте не нужен
.DS_Store
