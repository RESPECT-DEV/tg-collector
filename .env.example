# Скопируй этот файл в .env и заполни своими значениями:
# cp .env.example .env

# Токен бота — получить у @BotFather в Telegram
BOT_TOKEN=

# Публичный HTTPS-адрес сервера (без слэша в конце)
# Для локальной разработки использовать ngrok: ngrok http 3000
WEBHOOK_URL=

# URL эндпоинта бэкенда, куда бот отправляет данные сообщений
BACKEND_ENDPOINT=

# Порт Express-сервера
PORT=3000

# Секрет для проверки подлинности webhook-запросов от Telegram.
# Telegram будет добавлять его в заголовок X-Telegram-Bot-Api-Secret-Token.
# Сгенерировать можно командой: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=
